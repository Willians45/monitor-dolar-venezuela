<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_centerInParent="true">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monitor Dólar"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/rate_bcv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BCV: 36.32"
                android:textColor="#60a5fa"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:background="#33FFFFFF"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="8dp" />

            <TextView
                android:id="@+id/rate_binance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USDT: 38.50"
                android:textColor="#facc15"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
        
        <TextView
            android:id="@+id/widget_update_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Actualizando..."
            android:textColor="#88FFFFFF"
            android:textSize="10sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp" />
    </LinearLayout>
</RelativeLayout>
